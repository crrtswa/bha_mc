# Git ignore require removal of cached for file that was previously tracked
# To update the tracked cache, run the two commands below
# git rm -r --cached .
# git add .
# ---------------------------------------------------------------------------------------------------------------------------

# Visual Studio cache/options directory
.vs/

# TwinCAT files  https://alltwincat.com/2019/12/02/gitignore-for-twincat/
# Also verified with Nick from Beckhoff

# from TwinCAT 3.1 version 4018+, no longer needs to be under Source Control administration!
*.tmc

# Ignore all types of backup files generated by TwinCAT
*.bak

# Ignore any VSSettings folder (mainly for Scope project)
*/VSSettings/

# Ignore compiled, generated folders
_Boot/
_CompileInfo/
_Libraries/

# Ignore weird Tc files
*.~
*.~u

# Ignore tpy is Beckhoff recommended, the other are Nick's shareable ignore file. Probably include C++ type projects
*.tpy
*.tclrs
*.tmcRefac
LineIDs.dbg

# For most applications, exluding the ModuleInstall folder is not an issue (it houses TMX files for versioned TcCom objects).
# If using multiple versions of compiled C++ changable module, then might want to leave this folder under souce control as not to
# have to check out every older C++ project for C++ module version and compile. 
_ModuleInstall/ 

# TwinCAT HMI
# TC HMI also creates it's own Ignore file inside every new project
.engineering_servers/
liveview_*
*.cache
*.db-shm
*.db-wal
*.pid
tchmipublish.journal.json

# TC HMI 1.12 Additional
.hmiframework/
.hmipkgs/*-*-*-*/

# More Visual Studio recommened 

# Log files
*.log

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Pictures
*.jpeg
*.png
*.pdf